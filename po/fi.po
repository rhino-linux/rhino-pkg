#: rhino-pkg:144 rhino-pkg:236 rhino-pkg:328
#, python-brace-format
msgid "No packages found matching '{rest}'!"
msgstr "Ei löydetty paketteja, jotka vastaavat '{rest}'!"

#: rhino-pkg:254
#, python-brace-format
msgid "Select which packages to install"
msgstr "Valitse mitkä paketit asennetaan"

#: rhino-pkg:256
#, python-brace-format
msgid "Selecting '{pkg}' from package manager '{provider}'"
msgstr "Valitaan '{pkg}' paketinhallintaohjelmasta '{provider}'"

#: rhino-pkg:264 rhino-pkg:345
#, python-brace-format
msgid "Are you sure? ({y}/{n}) "
msgstr "Oletko varma? ({y}/{n}) "

#: rhino-pkg:293
#, python-brace-format
msgid "Failed to install '{pkg}'."
msgstr "'{pkg}' asennus epäonnistui."

#: rhino-pkg:336
#, python-brace-format
msgid "Select which package to remove"
msgstr "Valitse mitkä paketit poistetaan"

#: rhino-pkg:338
#, python-brace-format
msgid "Removing '{part}' from '{provider}'"
msgstr "Poistetaan '{part}' toimittajalta '{provider}'"

#: rhino-pkg:377
#, python-brace-format
msgid ""
"Attempting to repair dependencies and remove unused packages. Continue? ({y}/"
"{n}) "
msgstr ""
"Yritetään korjata riippuvuuksia ja poistaa käyttämättömiä paketteja. "
"Jatketaanko? ({y}/{n}) "

#: rhino-pkg:428
#, python-brace-format
msgid "Are you sure you want to update all packages? ({y}/{n}) "
msgstr "Haluatko varmasti päivittää kaikki paketit? ({y}/{n}) "

#: cmd.nu:38 cmd.nu:48
#, python-brace-format
